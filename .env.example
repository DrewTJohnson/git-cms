# Copy this to .env.local for local development
# These are injected at build time by Vite

# Your GitHub username or organization name
VITE_REPO_OWNER=your-username

# The name of this repository
VITE_REPO_NAME=git-cms

# The branch where content is stored
VITE_DEFAULT_BRANCH=main

# The base URL path for GitHub Pages (e.g., /repo-name/ for project pages, / for user pages)
# Set automatically by GitHub Actions — only set this manually for local preview
VITE_BASE_PATH=/
